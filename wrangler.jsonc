{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edulab-site",
  "compatibility_date": "2026-06-04",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "edulab.ai", "custom_domain": true },
    { "pattern": "www.edulab.ai", "custom_domain": true }
  ]
}
